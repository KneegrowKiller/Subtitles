Dialogue: 0,0:02:48.48,0:02:54.28,Staff,,0,0,0,,{\b1\fs84\bord2\blur20\1c&H50C05B&\3c&HAEE9FF&\fscy90\fad(918,918)\pos(940,840)}2nd. {\1c&HB655FE&}可奈美篇
Comment: 0,0:00:00.00,0:00:00.00,JP,,0,0,0,,Text-JP
Dialogue: 0,0:00:01.80,0:00:02.76,JP,,0,0,0,,お兄ちゃん…
Dialogue: 0,0:00:04.90,0:00:05.99,JP,,0,0,0,,お兄ちゃんなら
Dialogue: 0,0:00:08.76,0:00:09.51,JP,,0,0,0,,いいよ
Dialogue: 0,0:00:12.56,0:00:15.43,JP,,0,0,0,,お…お兄ちゃん　おっぱい星人だから
Dialogue: 0,0:00:15.62,0:00:19.04,JP,,0,0,0,,こなみのおっぱいにすっごいいけないことしちゃうぞ
Dialogue: 0,0:00:20.92,0:00:24.17,JP,,0,0,0,,こんなふうに　乳輪舐め回したり
Dialogue: 0,0:00:27.26,0:00:30.05,JP,,0,0,0,,丸ごとムチューって吸っちゃったり
Dialogue: 0,0:00:35.31,0:00:39.48,JP,,0,0,0,,そんでもって　おっぱいの先っぽコロコロチューチューしながら
Dialogue: 0,0:00:40.14,0:00:44.16,JP,,0,0,0,,こなみの桃みたいなおマンコ　こね回しちゃったりしちゃうぞ
Dialogue: 0,0:00:47.30,0:00:48.26,JP,,0,0,0,,お兄ちゃん…
Dialogue: 0,0:00:52.04,0:00:53.74,JP,,0,0,0,,もう　してるよ
Dialogue: 0,0:00:54.58,0:00:57.12,JP,,0,0,0,,もう　全部しちゃってるの
Dialogue: 0,0:01:01.42,0:01:07.80,JP,,0,0,0,,こんなところ　こなみん家のおじさんおばさんに見られたら　どうなるかな
Dialogue: 0,0:01:10.64,0:01:13.39,JP,,0,0,0,,こなみを預けて旅行に行ってる隙に
Dialogue: 0,0:01:13.74,0:01:15.60,JP,,0,0,0,,こんなことになるなんて
Dialogue: 0,0:01:17.39,0:01:18.85,JP,,0,0,0,,後悔してるか
Dialogue: 0,0:01:20.23,0:01:22.38,JP,,0,0,0,,ううん　してないよ
Dialogue: 0,0:01:22.64,0:01:27.78,JP,,0,0,0,,だって　ずっとお兄ちゃんとこうなりたいって思ってたから
Dialogue: 0,0:01:29.11,0:01:29.94,JP,,0,0,0,,だから…
Dialogue: 0,0:01:30.42,0:01:31.34,JP,,0,0,0,,こなみ
Dialogue: 0,0:01:33.18,0:01:34.57,JP,,0,0,0,,こなみ
Dialogue: 0,0:01:34.57,0:01:39.44,JP,,0,0,0,,そんな嬉しいこと言われたら　お兄ちゃん腰が止まらなくなっちゃうんだろう
Dialogue: 0,0:01:40.04,0:01:41.79,JP,,0,0,0,,いや…お兄ちゃん…
Dialogue: 0,0:01:42.72,0:01:44.16,JP,,0,0,0,,孕ませちゃうからな
Dialogue: 0,0:01:44.84,0:01:48.18,JP,,0,0,0,,今日　こなみを絶対孕ませちゃうからな
Dialogue: 0,0:01:49.76,0:01:54.46,JP,,0,0,0,,いいよ　こなみ…お兄ちゃんのお嫁さんになる
Dialogue: 0,0:01:55.50,0:01:56.54,JP,,0,0,0,,出しちゃうからな
Dialogue: 0,0:01:57.40,0:02:01.82,JP,,0,0,0,,こなみの…一番奥にたっぷり
Dialogue: 0,0:02:03.23,0:02:04.16,JP,,0,0,0,,して
Dialogue: 0,0:02:05.24,0:02:08.44,JP,,0,0,0,,中にいっぱいピュッピュして
Dialogue: 0,0:02:09.19,0:02:10.15,JP,,0,0,0,,こなみ
Dialogue: 0,0:02:27.54,0:02:28.30,JP,,0,0,0,,イク…
Dialogue: 0,0:02:36.86,0:02:37.66,JP,,0,0,0,,こなみ…
Dialogue: 0,0:02:39.30,0:02:42.22,JP,,0,0,0,,こなみ　こなみ…
Dialogue: 0,0:02:44.52,0:02:46.42,JP,,0,0,0,,こなみ…
Dialogue: 0,0:02:55.68,0:02:56.99,JP,,0,0,0,,こなみ…
Dialogue: 0,0:02:58.16,0:03:00.08,JP,,0,0,0,,呼んだ？お兄ちゃん
Dialogue: 0,0:03:01.48,0:03:02.74,JP,,0,0,0,,な…なんでもない
Dialogue: 0,0:03:03.10,0:03:04.83,JP,,0,0,0,,ちょっと寝惚けてて…
Dialogue: 0,0:03:06.12,0:03:09.14,JP,,0,0,0,,もしかして　私の夢見てたの？
Dialogue: 0,0:03:13.54,0:03:15.86,JP,,0,0,0,,ち…違う…違うって
Dialogue: 0,0:03:16.18,0:03:17.32,JP,,0,0,0,,ちょっとトイレ…
Dialogue: 0,0:03:24.84,0:03:29.30,JP,,0,0,0,,今日は　隣ん家のこなみの両親とうちの両親が旅行中で
Dialogue: 0,0:03:29.88,0:03:32.23,JP,,0,0,0,,こなみが夕食を作りに来てくれている
Dialogue: 0,0:03:34.30,0:03:36.22,JP,,0,0,0,,そのお皿はそっちに置いて
Dialogue: 0,0:03:36.86,0:03:37.46,JP,,0,0,0,,ここか
Dialogue: 0,0:03:38.36,0:03:39.70,JP,,0,0,0,,じゃあ　お兄ちゃん食べよ
Dialogue: 0,0:03:39.70,0:03:41.70,JP,,0,0,0,,うん　美味しそうだな
Dialogue: 0,0:03:41.70,0:03:43.29,JP,,0,0,0,,小さい頃から一緒で
Dialogue: 0,0:03:43.58,0:03:47.28,JP,,0,0,0,,本当の妹…みたいに思っていたが
Dialogue: 0,0:03:48.50,0:03:51.66,JP,,0,0,0,,成長…したよな
Dialogue: 0,0:03:52.70,0:03:53.58,JP,,0,0,0,,特に…
Dialogue: 0,0:03:54.98,0:03:55.80,JP,,0,0,0,,一部…
Dialogue: 0,0:04:01.18,0:04:02.24,JP,,0,0,0,,いかんいかん
Dialogue: 0,0:04:21.56,0:04:26.86,JP,,0,0,0,,おっぱいが…食後のデザートですと言わんばかりに
Dialogue: 0,0:04:34.24,0:04:35.64,JP,,0,0,0,,い…いかんいかん
Dialogue: 0,0:04:37.67,0:04:38.58,JP,,0,0,0,,しかし…
Dialogue: 0,0:04:40.12,0:04:43.00,JP,,0,0,0,,よく…寝ているな
Dialogue: 0,0:04:46.78,0:04:47.77,JP,,0,0,0,,ごめん　こなみ
Dialogue: 0,0:04:49.42,0:04:51.90,JP,,0,0,0,,お兄ちゃんにひと揉みだけの夢を
Dialogue: 0,0:05:00.91,0:05:03.38,JP,,0,0,0,,たまんねぇ
Dialogue: 0,0:05:08.04,0:05:10.34,JP,,0,0,0,,ダメだ　止まんない
Dialogue: 0,0:05:20.66,0:05:25.00,JP,,0,0,0,,生で揉んだら　もっと気持ちいいんだろうな
Dialogue: 0,0:05:31.14,0:05:33.36,JP,,0,0,0,,か…陥没！
Dialogue: 0,0:05:33.86,0:05:35.78,JP,,0,0,0,,こんな嬉しいサプライズが…
Dialogue: 0,0:05:37.16,0:05:41.00,JP,,0,0,0,,こなみは　こんなところも恥ずかしがり屋さんなんだ
Dialogue: 0,0:05:52.50,0:05:55.74,JP,,0,0,0,,よーし　今助け出してやるぞ
Dialogue: 0,0:06:00.34,0:06:02.47,JP,,0,0,0,,こ…こなみ　起きてたのか
Dialogue: 0,0:06:04.00,0:06:06.32,JP,,0,0,0,,こ…これはだな　その…
Dialogue: 0,0:06:06.80,0:06:11.10,JP,,0,0,0,,おっぱいの感触が気持ちよすぎて　手が離せない
Dialogue: 0,0:06:15.42,0:06:17.82,JP,,0,0,0,,こなみ　どうして何も言わないんだ
Dialogue: 0,0:06:31.06,0:06:32.42,JP,,0,0,0,,こなみ　感じてる？
Dialogue: 0,0:06:35.29,0:06:37.30,JP,,0,0,0,,こ…こなみ！
Dialogue: 0,0:07:00.48,0:07:03.42,JP,,0,0,0,,い…いやだ　ダメ…
Dialogue: 0,0:07:25.32,0:07:26.00,JP,,0,0,0,,あれ？
Dialogue: 0,0:07:30.43,0:07:31.18,JP,,0,0,0,,こなみ？
Dialogue: 0,0:07:37.52,0:07:42.30,JP,,0,0,0,,す…すごっ　こなみのおマンコ　アツっ
Dialogue: 0,0:07:49.72,0:07:51.70,JP,,0,0,0,,奥まで入ったぞ　こなみ
Dialogue: 0,0:07:53.42,0:07:56.79,JP,,0,0,0,,おマンコ肉　お餅みたいに張り付いてきて
Dialogue: 0,0:07:57.74,0:07:59.88,JP,,0,0,0,,おちんちん行っちゃうのが寂しいのか
Dialogue: 0,0:08:06.26,0:08:08.78,JP,,0,0,0,,こなみは抜く時が気持ちいいんだな？
Dialogue: 0,0:08:09.10,0:08:11.06,JP,,0,0,0,,いや…違う…
Dialogue: 0,0:08:16.40,0:08:17.74,JP,,0,0,0,,ムチムチのお尻
Dialogue: 0,0:08:18.90,0:08:21.19,JP,,0,0,0,,突くたびにプルプル揺れてる
Dialogue: 0,0:08:28.54,0:08:30.20,JP,,0,0,0,,こなみぬくぬく
Dialogue: 0,0:08:30.50,0:08:32.26,JP,,0,0,0,,抱き心地最高
Dialogue: 0,0:08:33.66,0:08:37.50,JP,,0,0,0,,こなみのおマンコ　お兄ちゃんの形にするからな
Dialogue: 0,0:08:45.22,0:08:49.98,JP,,0,0,0,,こね回すたびに　いやらしいメスの匂いが立ち込めて
Dialogue: 0,0:08:51.08,0:08:54.56,JP,,0,0,0,,おかしくなりそうだ　こなみ
Dialogue: 0,0:09:05.11,0:09:07.10,JP,,0,0,0,,お…お兄ちゃん…
Dialogue: 0,0:09:10.18,0:09:13.78,JP,,0,0,0,,好き…お兄ちゃん…
Dialogue: 0,0:09:16.44,0:09:17.75,JP,,0,0,0,,こなみ！
Dialogue: 0,0:09:19.44,0:09:20.76,JP,,0,0,0,,もう止まんねぇ
Dialogue: 0,0:09:21.70,0:09:22.90,JP,,0,0,0,,可愛いすぎる
Dialogue: 0,0:09:23.96,0:09:26.44,JP,,0,0,0,,なあ　中に出しちゃうからな
Dialogue: 0,0:09:30.80,0:09:31.60,JP,,0,0,0,,いや…
Dialogue: 0,0:09:32.48,0:09:36.20,JP,,0,0,0,,なんか　気持ちいいよ
Dialogue: 0,0:09:39.84,0:09:43.74,JP,,0,0,0,,い…行くぞ　こなみのおマンコに
Dialogue: 0,0:09:46.90,0:09:47.42,JP,,0,0,0,,出る
Dialogue: 0,0:09:58.58,0:10:00.40,JP,,0,0,0,,お兄ちゃん…
Dialogue: 0,0:10:06.02,0:10:07.02,JP,,0,0,0,,好き…
Dialogue: 0,0:10:11.42,0:10:12.64,JP,,0,0,0,,こなみ…
Dialogue: 0,0:10:14.68,0:10:15.50,JP,,0,0,0,,また夢？
Dialogue: 0,0:10:16.93,0:10:19.06,JP,,0,0,0,,俺どんだけこなみ好きなんだよ
Dialogue: 0,0:10:27.06,0:10:28.42,JP,,0,0,0,,げ…現実？
Dialogue: 0,0:10:29.23,0:10:29.76,JP,,0,0,0,,うん…
Dialogue: 0,0:10:30.50,0:10:34.26,JP,,0,0,0,,お兄ちゃんがあんなにエッチだなんて　知らなかった
Dialogue: 0,0:10:41.79,0:10:43.70,JP,,0,0,0,,もう　ベタベタだよ
Dialogue: 0,0:10:45.92,0:10:48.00,JP,,0,0,0,,お兄ちゃん　お風呂借りるね
Dialogue: 0,0:10:48.58,0:10:50.34,JP,,0,0,0,,こ…こなみ！
Dialogue: 0,0:10:57.92,0:11:00.92,JP,,0,0,0,,現実なんだったら　もう一回　いいだろう　な？
Dialogue: 0,0:11:01.10,0:11:02.70,JP,,0,0,0,,お…お兄ちゃん…
Dialogue: 0,0:11:07.64,0:11:10.30,JP,,0,0,0,,こなみはおっぱいの中も気持ちいい
Dialogue: 0,0:11:10.42,0:11:15.40,JP,,0,0,0,,お…お兄ちゃん　こんなの恥ずかしい…
Dialogue: 0,0:11:16.40,0:11:18.56,JP,,0,0,0,,こなみだって感じてるんだろう？
Dialogue: 0,0:11:26.66,0:11:29.00,JP,,0,0,0,,そんなこと…ないよ
Dialogue: 0,0:11:30.38,0:11:32.28,JP,,0,0,0,,俺は気持ちよすぎて
Dialogue: 0,0:11:34.12,0:11:36.60,JP,,0,0,0,,もう…ダメだ
Dialogue: 0,0:11:43.02,0:11:45.60,JP,,0,0,0,,これだけ出しても　まだ元気だ
Dialogue: 0,0:11:55.46,0:11:57.82,JP,,0,0,0,,さっきもう一回って…
Dialogue: 0,0:11:59.96,0:12:01.96,JP,,0,0,0,,細かいこと気にすんな
Dialogue: 0,0:12:03.56,0:12:06.86,JP,,0,0,0,,おマンコの中　また俺の形になったぞ
Dialogue: 0,0:12:08.54,0:12:10.28,JP,,0,0,0,,お兄ちゃんの形…
Dialogue: 0,0:12:15.46,0:12:17.90,JP,,0,0,0,,こなみの中キツくて
Dialogue: 0,0:12:19.12,0:12:22.81,JP,,0,0,0,,おちんちんのほうが　こなみの形になっちゃいそうだ
Dialogue: 0,0:12:24.50,0:12:27.48,JP,,0,0,0,,いやだ　お兄ちゃんの形がいい
Dialogue: 0,0:12:28.30,0:12:31.64,JP,,0,0,0,,私　お兄ちゃん専用になりたい
Dialogue: 0,0:12:32.15,0:12:33.24,JP,,0,0,0,,こなみ！
Dialogue: 0,0:13:22.28,0:13:23.86,JP,,0,0,0,,もう　信じらんない
Dialogue: 0,0:13:24.28,0:13:28.18,JP,,0,0,0,,初めてだったのに　あんなにこね回して　中出しまでして
Dialogue: 0,0:13:28.58,0:13:30.58,JP,,0,0,0,,妊娠しちゃったらどうするの？
Dialogue: 0,0:13:30.78,0:13:34.46,JP,,0,0,0,,ご…ごめん　でもちゃんと責任取るから
Dialogue: 0,0:13:38.63,0:13:39.66,JP,,0,0,0,,約束だよ
Dialogue: 0,0:13:40.72,0:13:41.62,JP,,0,0,0,,お兄ちゃん
Dialogue: 0,0:13:55.64,0:13:58.56,JP,,0,0,0,,それじゃあ　寝る前にもう一回？
Dialogue: 0,0:13:58.57,0:14:01.10,JP,,0,0,0,,もう　お兄ちゃんったら
Comment: 0,0:00:00.00,0:00:00.00,CN,,0,0,0,,Text-CN
Dialogue: 0,0:00:01.80,0:00:02.76,CN,,0,0,0,,哥哥…
Dialogue: 0,0:00:04.90,0:00:05.99,CN,,0,0,0,,如果是哥哥的话
Dialogue: 0,0:00:08.76,0:00:09.51,CN,,0,0,0,,可以哦
Dialogue: 0,0:00:12.56,0:00:15.43,CN,,0,0,0,,哥…哥哥我是奶子星人啊
Dialogue: 0,0:00:15.62,0:00:19.04,CN,,0,0,0,,我要对可奈美的奶子做非常过分的事
Dialogue: 0,0:00:20.92,0:00:24.17,CN,,0,0,0,,像这样来回舔乳晕
Dialogue: 0,0:00:27.26,0:00:30.05,CN,,0,0,0,,把整个乳头都吸住
Dialogue: 0,0:00:35.31,0:00:39.48,CN,,0,0,0,,然后像这样来回吮吸乳头
Dialogue: 0,0:00:40.14,0:00:44.16,CN,,0,0,0,,再不停地搅动可奈美的水蜜桃小穴
Dialogue: 0,0:00:47.30,0:00:48.26,CN,,0,0,0,,哥哥…
Dialogue: 0,0:00:52.04,0:00:53.74,CN,,0,0,0,,你已经在这么做了
Dialogue: 0,0:00:54.58,0:00:57.12,CN,,0,0,0,,已经都做了
Dialogue: 0,0:01:01.42,0:01:07.80,CN,,0,0,0,,这副样子 要是被叔叔阿姨看见了会怎么办
Dialogue: 0,0:01:10.64,0:01:13.39,CN,,0,0,0,,自己出去旅游 把可奈美放在我家的这段时间
Dialogue: 0,0:01:13.74,0:01:15.60,CN,,0,0,0,,居然发生了这种事
Dialogue: 0,0:01:17.39,0:01:18.85,CN,,0,0,0,,你会后悔吗
Dialogue: 0,0:01:20.23,0:01:22.38,CN,,0,0,0,,不会哦
Dialogue: 0,0:01:22.64,0:01:27.78,CN,,0,0,0,,因为我一直想和哥哥做这种事
Dialogue: 0,0:01:29.11,0:01:29.94,CN,,0,0,0,,所以…
Dialogue: 0,0:01:30.42,0:01:31.34,CN,,0,0,0,,可奈美
Dialogue: 0,0:01:33.18,0:01:34.57,CN,,0,0,0,,可奈美
Dialogue: 0,0:01:34.57,0:01:39.44,CN,,0,0,0,,要是说这种令人高兴的话 哥哥我的腰就停不下来了
Dialogue: 0,0:01:40.04,0:01:41.79,CN,,0,0,0,,不要…哥哥…
Dialogue: 0,0:01:42.72,0:01:44.16,CN,,0,0,0,,我要让你怀孕
Dialogue: 0,0:01:44.84,0:01:48.18,CN,,0,0,0,,今天绝对要让你怀孕
Dialogue: 0,0:01:49.76,0:01:54.46,CN,,0,0,0,,可以哦 可奈美…要嫁给哥哥
Dialogue: 0,0:01:55.50,0:01:56.54,CN,,0,0,0,,我要射了
Dialogue: 0,0:01:57.40,0:02:01.82,CN,,0,0,0,,全都…射在可奈美的子宫里吧
Dialogue: 0,0:02:03.23,0:02:04.16,CN,,0,0,0,,射吧
Dialogue: 0,0:02:05.24,0:02:08.44,CN,,0,0,0,,全都射在里面
Dialogue: 0,0:02:09.19,0:02:10.15,CN,,0,0,0,,可奈美
Dialogue: 0,0:02:27.54,0:02:28.30,CN,,0,0,0,,我要射了…
Dialogue: 0,0:02:36.86,0:02:37.66,CN,,0,0,0,,可奈美…
Dialogue: 0,0:02:39.30,0:02:42.22,CN,,0,0,0,,可奈美 可奈美…
Dialogue: 0,0:02:44.52,0:02:46.42,CN,,0,0,0,,可奈美…
Dialogue: 0,0:02:55.68,0:02:56.99,CN,,0,0,0,,可奈美…
Dialogue: 0,0:02:58.16,0:03:00.08,CN,,0,0,0,,哥哥 你叫我？
Dialogue: 0,0:03:01.48,0:03:02.74,CN,,0,0,0,,没…没什么
Dialogue: 0,0:03:03.10,0:03:04.83,CN,,0,0,0,,有点睡糊涂了…
Dialogue: 0,0:03:06.12,0:03:09.14,CN,,0,0,0,,难道梦到我了？
Dialogue: 0,0:03:13.54,0:03:15.86,CN,,0,0,0,,不…不是…才没有
Dialogue: 0,0:03:16.18,0:03:17.32,CN,,0,0,0,,我去下厕所…
Dialogue: 0,0:03:24.84,0:03:29.30,CN,,0,0,0,,今天 隔壁可奈美的父母和我爸妈都去旅游了
Dialogue: 0,0:03:29.88,0:03:32.23,CN,,0,0,0,,可奈美来给我做晚饭
Dialogue: 0,0:03:34.30,0:03:36.22,CN,,0,0,0,,那个盘子就放这里吧
Dialogue: 0,0:03:36.86,0:03:37.46,CN,,0,0,0,,这里吗
Dialogue: 0,0:03:38.36,0:03:39.70,CN,,0,0,0,,那哥哥就开动吧
Dialogue: 0,0:03:39.70,0:03:41.70,CN,,0,0,0,,嗯 看起来很好吃
Dialogue: 0,0:03:41.70,0:03:43.29,CN,,0,0,0,,我们从小就在一起
Dialogue: 0,0:03:43.58,0:03:47.28,CN,,0,0,0,,本来…是把她当亲妹妹一样
Dialogue: 0,0:03:48.50,0:03:51.66,CN,,0,0,0,,但她…成长了不少啊
Dialogue: 0,0:03:52.70,0:03:53.58,CN,,0,0,0,,尤其是…
Dialogue: 0,0:03:54.98,0:03:55.80,CN,,0,0,0,,某些部位…
Dialogue: 0,0:04:01.18,0:04:02.24,CN,,0,0,0,,不行不行
Dialogue: 0,0:04:21.56,0:04:26.86,CN,,0,0,0,,这奶子…刚想说吃完饭想吃甜点来着
Dialogue: 0,0:04:34.24,0:04:35.64,CN,,0,0,0,,不…不行不行
Dialogue: 0,0:04:37.67,0:04:38.58,CN,,0,0,0,,可是…
Dialogue: 0,0:04:40.12,0:04:43.00,CN,,0,0,0,,好像…睡着了
Dialogue: 0,0:04:46.78,0:04:47.77,CN,,0,0,0,,抱歉 可奈美
Dialogue: 0,0:04:49.42,0:04:51.90,CN,,0,0,0,,让哥哥做个揉胸的梦吧
Dialogue: 0,0:05:00.91,0:05:03.38,CN,,0,0,0,,根本忍不住啊
Dialogue: 0,0:05:08.04,0:05:10.34,CN,,0,0,0,,不行 停不下来了
Dialogue: 0,0:05:20.66,0:05:25.00,CN,,0,0,0,,要是直接揉的话 肯定会更舒服吧
Dialogue: 0,0:05:31.14,0:05:33.36,CN,,0,0,0,,内…内陷乳头！
Dialogue: 0,0:05:33.86,0:05:35.78,CN,,0,0,0,,居然会有这样的惊喜…
Dialogue: 0,0:05:37.16,0:05:41.00,CN,,0,0,0,,可奈美连这种地方都这么怕羞啊
Dialogue: 0,0:05:52.50,0:05:55.74,CN,,0,0,0,,好 我现在就帮你弄出来
Dialogue: 0,0:06:00.34,0:06:02.47,CN,,0,0,0,,可…可奈美 你醒了啊
Dialogue: 0,0:06:04.00,0:06:06.32,CN,,0,0,0,,这…这个是 那个…
Dialogue: 0,0:06:06.80,0:06:11.10,CN,,0,0,0,,奶子的触感太棒了 手都离不开了
Dialogue: 0,0:06:15.42,0:06:17.82,CN,,0,0,0,,可奈美为什么一句话都不说
Dialogue: 0,0:06:31.06,0:06:32.42,CN,,0,0,0,,可奈美 你来感觉了？
Dialogue: 0,0:06:35.29,0:06:37.30,CN,,0,0,0,,可…可奈美！
Dialogue: 0,0:07:00.48,0:07:03.42,CN,,0,0,0,,不…不要 不可以…
Dialogue: 0,0:07:25.32,0:07:26.00,CN,,0,0,0,,咦？
Dialogue: 0,0:07:30.43,0:07:31.18,CN,,0,0,0,,可奈美？
Dialogue: 0,0:07:37.52,0:07:42.30,CN,,0,0,0,,好…好厉害 可奈美的小穴热热的
Dialogue: 0,0:07:49.72,0:07:51.70,CN,,0,0,0,,我要插进去了 可奈美
Dialogue: 0,0:07:53.42,0:07:56.79,CN,,0,0,0,,小穴的肉壁像年糕一样紧紧贴着我
Dialogue: 0,0:07:57.74,0:07:59.88,CN,,0,0,0,,肉棒出来的时候会觉得寂寞吗
Dialogue: 0,0:08:06.26,0:08:08.78,CN,,0,0,0,,可奈美是不是喜欢肉棒拔出来的感觉？
Dialogue: 0,0:08:09.10,0:08:11.06,CN,,0,0,0,,不…不是…
Dialogue: 0,0:08:16.40,0:08:17.74,CN,,0,0,0,,好丰满的屁股
Dialogue: 0,0:08:18.90,0:08:21.19,CN,,0,0,0,,每次往里面插就会晃个不停
Dialogue: 0,0:08:28.54,0:08:30.20,CN,,0,0,0,,可奈美身上暖暖的
Dialogue: 0,0:08:30.50,0:08:32.26,CN,,0,0,0,,抱起来的感觉太棒了
Dialogue: 0,0:08:33.66,0:08:37.50,CN,,0,0,0,,我要把可奈美的小穴变成我的形状
Dialogue: 0,0:08:45.22,0:08:49.98,CN,,0,0,0,,每次搅动就会散发出雌性的淫荡气息
Dialogue: 0,0:08:51.08,0:08:54.56,CN,,0,0,0,,要变得奇怪了 可奈美
Dialogue: 0,0:09:05.11,0:09:07.10,CN,,0,0,0,,哥…哥哥…
Dialogue: 0,0:09:10.18,0:09:13.78,CN,,0,0,0,,好喜欢…哥哥…
Dialogue: 0,0:09:16.44,0:09:17.75,CN,,0,0,0,,可奈美！
Dialogue: 0,0:09:19.44,0:09:20.76,CN,,0,0,0,,已经停不下来了
Dialogue: 0,0:09:21.70,0:09:22.90,CN,,0,0,0,,你太可爱了
Dialogue: 0,0:09:23.96,0:09:26.44,CN,,0,0,0,,让我射在里面吧
Dialogue: 0,0:09:30.80,0:09:31.60,CN,,0,0,0,,不要…
Dialogue: 0,0:09:32.48,0:09:36.20,CN,,0,0,0,,感觉好舒服
Dialogue: 0,0:09:39.84,0:09:43.74,CN,,0,0,0,,要…要射了 射进可奈美的小穴里
Dialogue: 0,0:09:46.90,0:09:47.42,CN,,0,0,0,,射了
Dialogue: 0,0:09:58.58,0:10:00.40,CN,,0,0,0,,哥哥…
Dialogue: 0,0:10:06.02,0:10:07.02,CN,,0,0,0,,喜欢你…
Dialogue: 0,0:10:11.42,0:10:12.64,CN,,0,0,0,,可奈美…
Dialogue: 0,0:10:14.68,0:10:15.50,CN,,0,0,0,,又是梦？
Dialogue: 0,0:10:16.93,0:10:19.06,CN,,0,0,0,,我是有多喜欢可奈美啊
Dialogue: 0,0:10:27.06,0:10:28.42,CN,,0,0,0,,是…是真的？
Dialogue: 0,0:10:29.23,0:10:29.76,CN,,0,0,0,,嗯…
Dialogue: 0,0:10:30.50,0:10:34.26,CN,,0,0,0,,没想到哥哥居然这么色
Dialogue: 0,0:10:41.79,0:10:43.70,CN,,0,0,0,,下面都黏糊糊的
Dialogue: 0,0:10:45.92,0:10:48.00,CN,,0,0,0,,哥哥 借一下浴室
Dialogue: 0,0:10:48.58,0:10:50.34,CN,,0,0,0,,可…可奈美！
Dialogue: 0,0:10:57.92,0:11:00.92,CN,,0,0,0,,既然是真的 那就再做一次吧 好不好？
Dialogue: 0,0:11:01.10,0:11:02.70,CN,,0,0,0,,哥…哥哥…
Dialogue: 0,0:11:07.64,0:11:10.30,CN,,0,0,0,,可奈美的奶子里也很舒服
Dialogue: 0,0:11:10.42,0:11:15.40,CN,,0,0,0,,哥…哥哥 这样太羞耻了…
Dialogue: 0,0:11:16.40,0:11:18.56,CN,,0,0,0,,可奈美也很有感觉吧？
Dialogue: 0,0:11:26.66,0:11:29.00,CN,,0,0,0,,才没有…这回事
Dialogue: 0,0:11:30.38,0:11:32.28,CN,,0,0,0,,我太舒服了
Dialogue: 0,0:11:34.12,0:11:36.60,CN,,0,0,0,,快要…不行了
Dialogue: 0,0:11:43.02,0:11:45.60,CN,,0,0,0,,虽然就这么射了 但还没软下去
Dialogue: 0,0:11:55.46,0:11:57.82,CN,,0,0,0,,你不是说做一次吗…
Dialogue: 0,0:11:59.96,0:12:01.96,CN,,0,0,0,,不要纠结这种小事了
Dialogue: 0,0:12:03.56,0:12:06.86,CN,,0,0,0,,我要再次把你的小穴变成我的形状
Dialogue: 0,0:12:08.54,0:12:10.28,CN,,0,0,0,,哥哥的形状…
Dialogue: 0,0:12:15.46,0:12:17.90,CN,,0,0,0,,可奈美的小穴好紧
Dialogue: 0,0:12:19.12,0:12:22.81,CN,,0,0,0,,肉棒都要变成可奈美的形状了
Dialogue: 0,0:12:24.50,0:12:27.48,CN,,0,0,0,,不要 变成哥哥的形状就行了
Dialogue: 0,0:12:28.30,0:12:31.64,CN,,0,0,0,,我想当哥哥的专属肉便器
Dialogue: 0,0:12:32.15,0:12:33.24,CN,,0,0,0,,可奈美！
Dialogue: 0,0:13:22.28,0:13:23.86,CN,,0,0,0,,真是不敢相信
Dialogue: 0,0:13:24.28,0:13:28.18,CN,,0,0,0,,第一次就这么用力 而且还内射了
Dialogue: 0,0:13:28.58,0:13:30.58,CN,,0,0,0,,要是怀孕了该怎么办？
Dialogue: 0,0:13:30.78,0:13:34.46,CN,,0,0,0,,抱…抱歉 但我会负责的
Dialogue: 0,0:13:38.63,0:13:39.66,CN,,0,0,0,,那就约好了
Dialogue: 0,0:13:40.72,0:13:41.62,CN,,0,0,0,,哥哥
Dialogue: 0,0:13:55.64,0:13:58.56,CN,,0,0,0,,那在睡觉之前再做一次吧？
Dialogue: 0,0:13:58.57,0:14:01.10,CN,,0,0,0,,真是的 哥哥大坏蛋
